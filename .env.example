# Accountia - Production Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
MYSQL_ROOT_PASSWORD=YOUR_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=accountia
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/accountia
SPRING_DATASOURCE_USERNAME=accountia
SPRING_DATASOURCE_PASSWORD=YOUR_DATABASE_PASSWORD
JPA_DDL_AUTO=update

# PostgreSQL (Reporting)
POSTGRES_DB=accountia_reporting
POSTGRES_USER=accountia
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Message Queue
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=accountia
RABBITMQ_PASSWORD=YOUR_RABBITMQ_PASSWORD

# Cache
REDIS_HOST=redis
REDIS_PORT=6379

# Service Discovery
EUREKA_SERVICE_URL=http://eureka-server:8761/eureka/

# Security (IMPORTANT: Use a strong, randomly generated secret!)
SECURITY_JWT_SECRET=YOUR_STRONG_JWT_SECRET_MIN_32_CHARACTERS

# CORS Settings (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Admin User Seeding
ADMIN_SEED_EMAIL=admin@yourdomain.com
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_TENANT_ID=tenant_default
ADMIN_SEED_PASSWORD=YOUR_ADMIN_PASSWORD
