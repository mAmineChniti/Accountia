      ]
    },

    {
      "name": "6. Comments (Threaded)",
      "item": [
        {
          "name": "6.1 Post a Comment on Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) pm.collectionVariables.set('comment_id', json.id);",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "console.log('Comment created:', json.id, '| Author:', json.authorName);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
